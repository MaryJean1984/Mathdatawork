<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.word.mapper.SysUserMapper">

    <!-- 自定义 SQL: 获取特定状态下且未被删除的用户 -->
    <select id="selectActiveUsersByStatus" resultType="com.word.entity.SysUser">
        SELECT 
            id, username, email, phone, status, create_time, update_time
        FROM sys_user 
        WHERE status = #{status} AND deleted = 0
    </select>

</mapper>
